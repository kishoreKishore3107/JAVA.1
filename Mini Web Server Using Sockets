import java.io.*;
import java.net.*;

public class MiniWebServer {

    public static void main(String[] args)
            throws Exception {

        ServerSocket server =
            new ServerSocket(8080);

        System.out.println(
            "Server Running...");

        while (true) {

            Socket client =
                server.accept();

            PrintWriter out =
                new PrintWriter(
                    client.getOutputStream(),
                    true);

            out.println(
                "HTTP/1.1 200 OK");
            out.println(
                "Content-Type: text/html");
            out.println();

            out.println(
                "<h1>Hello from Java Server</h1>");

            client.close();
        }
    }
}
